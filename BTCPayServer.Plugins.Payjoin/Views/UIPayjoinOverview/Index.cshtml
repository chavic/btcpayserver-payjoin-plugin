@using BTCPayServer.Abstractions.Constants
@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Client
@inject Microsoft.Extensions.Localization.IStringLocalizer StringLocalizer
@model BTCPayServer.Plugins.Payjoin.PayjoinOverviewViewModel
@{
    var store = Model.CurrentStore!;
}

<div class="sticky-header">
    <h2 text-translate="true">Payjoin V2</h2>
    <a id="page-primary"
       class="btn btn-primary"
       role="button"
       asp-controller="UIStorePayjoin"
       asp-action="Settings"
       asp-route-storeId="@store.StoreId"
       permission="@Policies.CanViewStoreSettings"
       permission-resource="@store.StoreId"
       text-translate="true">
        Open Settings
    </a>
</div>

<partial name="_StatusMessage" />

<div class="row mb-4">
    <div class="col-12 col-xl-8">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-3">
                    <div>
                        <h3 class="mb-1">@(string.IsNullOrEmpty(store.StoreName) ? StringLocalizer["Unnamed Store"].Value : store.StoreName)</h3>
                        <div class="text-muted">@store.StoreId</div>
                    </div>
                    <span class="badge @(store.Status.Severity == "success" ? "bg-success" : store.Status.Severity == "warning" ? "bg-warning text-dark" : "bg-danger")">
                        @store.Status.Title
                    </span>
                </div>

                <p class="mb-0">@store.Status.Message</p>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-2 mt-3 mt-xl-0">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted mb-2" text-translate="true">Default checkout mode</div>
                <div class="h4 mb-0">@(store.EnabledByDefault ? StringLocalizer["Payjoin V2"].Value : StringLocalizer["Standard BTC"].Value)</div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-6 col-xl-2 mt-3 mt-xl-0">
        <div class="card h-100">
            <div class="card-body">
                <div class="text-muted mb-2" text-translate="true">Receiver inputs</div>
                <div class="h4 mb-0">@(store.HasConfirmedReceiverInputs ? StringLocalizer["Present"].Value : StringLocalizer["Pending"].Value)</div>
            </div>
        </div>
    </div>
</div>

@if (store.Status.Severity == "warning")
{
    <div class="alert alert-warning mb-4" role="alert">
        <span text-translate="true">The basic Payjoin V2 prerequisites are configured, but no confirmed receiver inputs are currently available. Payjoin V2 will be skipped until the store wallet has spendable confirmed coins.</span>
    </div>
}
else if (store.Status.Severity == "danger")
{
    <div class="alert alert-danger mb-4" role="alert">
        <span text-translate="true">The selected store does not yet meet the basic Payjoin V2 prerequisites. Review the settings below and complete the missing requirements.</span>
    </div>
}

<div class="row">
    <div class="col-12 col-xl-8">
        <div class="card mb-4">
            <div class="card-body">
                <h4 class="card-title mb-4" text-translate="true">Configuration</h4>
                <dl class="mb-0 row">
                    <dt class="col-sm-4 text-muted" text-translate="true">Directory</dt>
                    <dd class="col-sm-8 mb-3">
                        @if (store.DirectoryUrl is null)
                        {
                            <span class="badge bg-danger" text-translate="true">Missing</span>
                        }
                        else
                        {
                            <span class="text-break">@store.DirectoryUrl</span>
                        }
                    </dd>

                    <dt class="col-sm-4 text-muted" text-translate="true">OHTTP relay</dt>
                    <dd class="col-sm-8 mb-3">
                        @if (store.OhttpRelayUrl is null)
                        {
                            <span class="badge bg-danger" text-translate="true">Missing</span>
                        }
                        else
                        {
                            <span class="text-break">@store.OhttpRelayUrl</span>
                        }
                    </dd>

                    <dt class="col-sm-4 text-muted" text-translate="true">Cold wallet</dt>
                    <dd class="col-sm-8 mb-3">
                        @if (store.HasColdWallet)
                        {
                            <span class="badge bg-success" text-translate="true">Configured</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary" text-translate="true">Not configured</span>
                        }
                    </dd>

                    <dt class="col-sm-4 text-muted" text-translate="true">Default checkout mode</dt>
                    <dd class="col-sm-8 mb-0">
                        @if (store.EnabledByDefault)
                        {
                            <span class="badge bg-success">@StringLocalizer["Payjoin V2"]</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@StringLocalizer["Standard BTC"]</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-4">
        <div class="card mb-4">
            <div class="card-body">
                <h4 class="card-title mb-4" text-translate="true">Basic prerequisites</h4>
                <div class="d-grid gap-3 mb-0">
                    <div class="d-flex align-items-center justify-content-between border-bottom pb-3">
                        <span text-translate="true">Directory configured</span>
                        <span class="badge @(store.DirectoryUrl is null ? "bg-danger" : "bg-success")">@(store.DirectoryUrl is null ? StringLocalizer["Missing"].Value : StringLocalizer["Present"].Value)</span>
                    </div>
                    <div class="d-flex align-items-center justify-content-between border-bottom pb-3">
                        <span text-translate="true">OHTTP relay configured</span>
                        <span class="badge @(store.OhttpRelayUrl is null ? "bg-danger" : "bg-success")">@(store.OhttpRelayUrl is null ? StringLocalizer["Missing"].Value : StringLocalizer["Present"].Value)</span>
                    </div>
                    <div class="d-flex align-items-center justify-content-between">
                        <span text-translate="true">Confirmed receiver inputs</span>
                        <span class="badge @(store.HasConfirmedReceiverInputs ? "bg-success" : "bg-warning text-dark")">@(store.HasConfirmedReceiverInputs ? StringLocalizer["Present"].Value : StringLocalizer["Pending"].Value)</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>